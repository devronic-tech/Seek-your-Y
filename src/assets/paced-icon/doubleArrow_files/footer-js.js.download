$("#mx_Interested_Product2").change(function(event) {
    var valueofproduct = $("select#mx_Interested_Product2 option:selected").text().replace('Interested in?','');
    if(valueofproduct == "MBA/MIM") {
        $("#lookingfor12").html(`<input type="hidden" name="mx_Looking_For" value="MBA/MIM" />`);
    } else if(valueofproduct == "MS/PhD") {
        $("#lookingfor12").html(`<input type="hidden" name="mx_Looking_For" value="MS/PhD" />`);

    } else if(valueofproduct == "UG") {
        $("#lookingfor12").html(`<input type="hidden" name="mx_Looking_For" value="UG" />`);
        
    } else {
        $("#lookingfor12").html(``);
    }
});

