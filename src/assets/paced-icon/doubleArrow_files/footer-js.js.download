$('#citycheckother').on('change', function() {
    var city_val = $("#citycheckother option:selected").text();
    console.log(city_val);
    if (city_val == "Chennai") {
        $('.selectpres1').remove();
        $(".nearbyyounewother").css("display", "block");
        $('.dom-newother').before().append('<select class="form-control selectpres1" name="field_nearest_centre" required><option value="" disabled="" selected="">Nearest Center</option>');
        $.each(chennai_city, function(i, p) {
            $('.selectpres1').append($('<option class="bld"></option>').val(p).html(i))
        })
        $('.selectpres1').append('</select>');
    } else if (city_val == "Delhi") {
        $('.selectpres1').remove();
        $(".nearbyyounewother").css("display", "block");
        $('.dom-newother').before().append('<select class="form-control selectpres1" name="field_nearest_centre" required><option value="" disabled="" selected="">Nearest Center</option>');
        $.each(delhi_city, function(i, p) {
            $('.selectpres1').append($('<option class="bld"></option>').val(p).html(i))
        })
        $('.selectpres1').append('</select>');
    } else if (city_val == "Hyderabad") {
        $('.selectpres1').remove();
        $(".nearbyyounewother").css("display", "block");
        $('.dom-newother').before().append('<select class="form-control selectpres1" name="field_nearest_centre" required><option value="" disabled="" selected="">Nearest Center</option>');
        $.each(hyderabad_city, function(i, p) {
            $('.selectpres1').append($('<option class="bld"></option>').val(p).html(i))
        })
        $('.selectpres1').append('</select>');
    } else if (city_val == "Kolkata") {
        $('.selectpres1').remove();
        $(".nearbyyounewother").css("display", "block");
        $('.dom-newother').before().append('<select class="form-control selectpres1" name="field_nearest_centre" required><option value="" disabled="" selected="">Nearest Center</option>');
        $.each(kolkata_city, function(i, p) {
            $('.selectpres1').append($('<option class="bld"></option>').val(p).html(i))
        })
        $('.selectpres1').append('</select>');
    } else if (city_val == "Mumbai") {
        $('.selectpres1').remove();
        $(".nearbyyounewother").css("display", "block");
        $('.dom-newother').before().append('<select class="form-control selectpres1" name="field_nearest_centre" required><option value="" disabled="" selected="">Nearest Center</option>');
        $.each(mumbai_city, function(i, p) {
            $('.selectpres1').append($('<option class="bld"></option>').val(p).html(i))
        })
        $('.selectpres1').append('</select>');
    } else if (city_val == "Pune") {
        $('.selectpres1').remove();
        $(".nearbyyounewother").css("display", "block");
        $('.dom-newother').before().append('<select class="form-control selectpres1" name="field_nearest_centre" required><option value="" disabled="" selected="">Nearest Center</option>');
        $.each(pune_city, function(i, p) {
            $('.selectpres1').append($('<option class="bld"></option>').val(p).html(i))
        })
        $('.selectpres1').append('</select>');        
    } else if (city_val == "Gurgaon") {
        $('.selectpres1').remove();
        $(".nearbyyounewother").css("display", "block");
        $('.dom-newother').before().append('<select class="form-control selectpres1" name="field_nearest_centre" required><option value="" disabled="" selected="">Nearest Center</option>');
        $.each(gurgaon_city, function(i, p) {
            $('.selectpres1').append($('<option class="bld"></option>').val(p).html(i))
        })
        $('.selectpres1').append('</select>');
    } else if (city_val == "Others") {
        $('.selectpres1').remove();
        $(".nearbyyounewother").css("display", "block");
        $('.dom-newother').before().append('<input placeholder="Your City/Location" class="form-control selectpres1" name="field_other_centers" required>');
    }
    else if(city_val == "Outside India") {
        $('.selectpres1').remove();
        $(".nearbyyounewother").css("display", "block");
        $('.dom-newother').before().append('<select class="form-control selectpres1" name="field_nearest_centre" required><option value="" disabled="" selected="">Nearest Center</option>');
        $.each(outside_india, function(i, p) {
            $('.selectpres1').append($('<option class="bld"></option>').val(p).html(i))
        })
        $('.selectpres1').append('</select>');        
    }
    else if(city_val == "Bangalore") {
        $('.selectpres1').remove();
        $(".nearbyyounewother").css("display", "block");
        $('.dom-newother').before().append('<select class="form-control selectpres1" name="field_nearest_centre" required><option value="" disabled="" selected="">Nearest Center</option>');
        $.each(bangalore_city, function(i, p) {
            $('.selectpres1').append($('<option class="bld"></option>').val(p).html(i))
        })
        $('.selectpres1').append('</select>');
    } 
    else if(city_val == "Vashi" || city_val == "Navi Mumbai") {
        $('.selectpres1').remove();
        $(".nearbyyounewother").css("display", "block");
        $('.dom-newother').before().append('<select class="form-control selectpres1" name="field_nearest_centre" required><option value="" disabled="" selected="">Nearest Center</option>');
        $.each(navi_mumbai_city, function(i, p) {
            $('.selectpres1').append($('<option class="bld"></option>').val(p).html(i))
        })
        $('.selectpres1').append('</select>');
    }
    else if(city_val == "Thane") {
        $('.selectpres1').remove();
        $(".nearbyyounewother").css("display", "block");
        $('.dom-newother').before().append('<select class="form-control selectpres1" name="field_nearest_centre" required><option value="" disabled="" selected="">Nearest Center</option>');
        $.each(thane_mumbai_city, function(i, p) {
            $('.selectpres1').append($('<option class="bld"></option>').val(p).html(i))
        })
        $('.selectpres1').append('</select>');
    } 
    else {
        $('.selectpres1').remove();
        $(".nearbyyounewother").css("display", "none");
        $('.dom-newother').before().append('<input type="hidden" value="' + city_val + '" class="form-control selectpres1" name="field_nearest_centre" required>');
    }
});
