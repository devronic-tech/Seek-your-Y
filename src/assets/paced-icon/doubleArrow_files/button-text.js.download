$(document).on('click', 'a', function () {
    var buttonTextSelect1 = $(this).html();
    buttonTextSelect1 = buttonTextSelect1.replace(/<img[^>]*>/g, '');
    var buttontext = '';
    if(buttonTextSelect1 == "") {
        buttonTextSelect1 = "BOOK A CALL";
        $(".buttontextchange").val(buttonTextSelect1);
    } else {
        $(".buttontextchange").val(buttonTextSelect1);
    }
    if(buttonTextSelect1 =="Start Your Application") { $(".main-title-jam").html("Let us save you a dozen oops moments, talk to a counsellor to start your application the right way!"); }
    if(buttonTextSelect1 =="Book a Call" || buttonTextSelect1 ==" BOOK A CALL"  || buttonTextSelect1 ==" Book a call" || buttonTextSelect1 == "BOOK A CALL") { 
        $(".main-title-jam").html("Let 30+ years of test prep and study-abroad excellence guide you on your journey"); 
    }
    if(buttonTextSelect1 == "Student Login") {
        $("#enroll-btn-online #exampleModalLabelfre").html("Log in to the Student Learning Portal for Mock Tests and Free Resources.");
        $("#enroll-btn-online #form-submit-button1").val("Submit");	
        $("#enroll-btn-online input[name='medium']").val("portal");
		$("#enroll-btn-online input[name='campaign']").val("student login");
    }
    if(buttonTextSelect1 == "Free Demo") {
        $("#enroll-btn-online #exampleModalLabelfre").html("Enroll for a FREE Demo Class");
        $("#enroll-btn-online #form-submit-button1").val("Free Demo");	
        $("#enroll-btn-online input[name='medium']").val("topbar");
		$("#enroll-btn-online input[name='campaign']").val("Free Demo");
    }

});

